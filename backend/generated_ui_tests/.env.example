# UI 自动化测试环境变量样板
# 用法: 复制为 .env (与 .spec.ts 同根 generated_ui_tests/.env),填实际值。
# 加载方式: helpers/auth.ts 顶部 `import "dotenv/config"` 自动注入 process.env。

# ----- 登录(loginAsDefault 默认读取) -----
UI_LOGIN_URL=https://172.16.8.190/
UI_LOGIN_USERNAME=superadmin
UI_LOGIN_PASSWORD=Admin@123

# ----- MidScene LLM(根据所用模型选一组配置) -----
# OpenAI 兼容(DeepSeek / Qwen / Doubao 等)
# MIDSCENE_MODEL_NAME=deepseek-chat
# OPENAI_API_KEY=sk-xxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
