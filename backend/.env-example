LLM_API_KEY=key
LLM_BASE_URL=url
LLM_MODEL=model

# ============================================================
# UI 自动化模块（一期）
# 零回归：UI_AUTOMATION_ENABLED=false 时模块整体停用，不影响 API 自动化
# ============================================================
UI_AUTOMATION_ENABLED=true
UI_PLAYWRIGHT_TIMEOUT=120
UI_HEADLESS=true
UI_BASE_URL=
UI_VIDEO_MODE=retain-on-failure
UI_TRACE_MODE=retain-on-failure
UI_MAX_VIDEO_SIZE_MB=50
UI_MAX_CONCURRENT_EXECUTIONS=2
UI_ARTIFACT_RETENTION_DAYS=7
UI_KEEP_LATEST_SUCCESS_REPORTS=20
# 降级演练：true 时所有 UI Agent 不调 LLM,直接走本地模板,便于 QA 验证降级路径
UI_AUTOMATION_FORCE_FALLBACK=false

# UI 子进程登录凭证(helpers/auth.ts 的 loginAsDefault 走这三个变量)
UI_LOGIN_URL=
UI_LOGIN_USERNAME=
UI_LOGIN_PASSWORD=

# MidScene.js 视觉 LLM —— 留空时 execution_service 自动回退到 DOUBAO_*
# 单配场景: 用一个跟生成器不同的视觉模型跑 aiAssert/aiWaitFor
UI_MIDSCENE_API_KEY=
UI_MIDSCENE_BASE_URL=
UI_MIDSCENE_MODEL_NAME=

# 豆包多模态视觉（火山引擎控制台开通 ark.cn-beijing.volces.com）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_VISION_MODEL=doubao-1-5-vision-pro-32k-250115
